# Required Vercel environment variables.
# Set these in your Vercel project: Settings -> Environment Variables.

# Your Anthropic API key (used by /api/generate).
ANTHROPIC_API_KEY=

# Abuse protection for the open /api/generate endpoint (both optional).
# Generations allowed per visitor IP per rolling hour. Default: 10
PER_IP_HOURLY_LIMIT=
# Total generations allowed across all visitors per rolling day. Default: 500
DAILY_GENERATION_CAP=
